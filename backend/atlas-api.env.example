# MongoDB Atlas Administration API keys (TASK O.6)
# Copy to atlas-api.env (gitignored). Never commit.
#
# Create keys: https://cloud.mongodb.com → Organization → Access Manager → API Keys
# Role: Project Owner or Project Network Access Manager on the SSC project.
#
ATLAS_PUBLIC_KEY=
ATLAS_PRIVATE_KEY=
# Optional — script can auto-discover via cluster name:
ATLAS_PROJECT_ID=
ATLAS_CLUSTER=ssc
# GCP Cloud NAT egress (from scripts/setup_gcp_nat_egress.ps1):
SSC_NAT_EGRESS_IP=34.140.240.41
# Founder laptop for local scripts / retention janitor (optional):
SSC_DEV_EGRESS_IP=